{
  "name": "cc-remote",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "build:agent": "pnpm --filter cc-remote-shared build && pnpm --filter cc-remote-agent build",
    "pack:agent": "pnpm run build:agent && (cd packages/agent && npm pack)",
    "release:agent": "bash scripts/publish-agent-npm.sh",
    "pack:agent-standalone": "bash scripts/pack-agent-standalone-tgz.sh"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.2.0",
    "prettier": "^3.4.2",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.0"
}
