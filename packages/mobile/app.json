{
  "expo": {
    "name": "CC Remote",
    "slug": "cc-remote",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "ccremote",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.ccremote.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app may need to access your camera for certain features.",
        "NSMicrophoneUsageDescription": "This app may need to access your microphone for certain features."
      }
    },
    "android": {
      "package": "com.ccremote.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
